# Copy to .env.development and adjust values.
# Run: npm run docker:dev   (or: docker compose --env-file .env.development up --build)
# Then in another terminal: npm run dev:web
#
# Compose publishes MySQL on host port 3307 and MinIO on 9100/9101 (see docker-compose.yml).
# From host tools (e.g. mysql client), use 127.0.0.1:3307 — the API container still uses DB_PORT=3306 to reach the mysql service.

API_PORT=4000

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=progress_tracker

JWT_SECRET=replace_me_in_development
JWT_EXPIRES_IN=7d

# Use minio when running the API against Docker Compose (overrides set DB_HOST/MINIO_ENDPOINT in compose for the api service).
STORAGE_PROVIDER=minio

MINIO_ENDPOINT=127.0.0.1
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin_secret_change_me
MINIO_BUCKET=progress-tracker
