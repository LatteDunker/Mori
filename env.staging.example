# Copy to .env.staging on the server and set real secrets (or wire to a secrets manager later).
#
# Deploy:
#   COMPOSE_ENV_FILE=.env.staging docker compose -f docker-compose.yml -f docker-compose.staging.yml --env-file .env.staging up -d --build
#
# Same variables as local dev; COMPOSE_ENV_FILE and --env-file must both point at this file.
# Internal Docker DNS: api still uses DB_HOST=mysql and MINIO_ENDPOINT=minio via docker-compose.yml.

API_PORT=4000

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=change_me_staging
DB_NAME=progress_tracker

JWT_SECRET=change_me_long_random_string
JWT_EXPIRES_IN=7d

STORAGE_PROVIDER=minio

MINIO_ENDPOINT=127.0.0.1
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=change_me
MINIO_SECRET_KEY=change_me
MINIO_BUCKET=progress-tracker
